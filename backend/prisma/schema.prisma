// Prisma schema for GLP-1 Eligibility Screening Form

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String   @id @default(uuid())
  status        String   @default("in_progress") // in_progress, completed, ineligible
  currentScreen Int      @default(1)
  result        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  answers       Answer[]

  @@map("sessions")
}

model Answer {
  id        String   @id @default(uuid())
  sessionId String
  screenId  Int
  answer    Json
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, screenId])
  @@map("answers")
}
